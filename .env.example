# =============================================================================
# Environment variables. Copy to .env for local docker-compose (auto-loaded),
# and set the cloud ones as secrets in GitHub Actions / Vercel. Never commit .env.
# =============================================================================

# --- Local docker-compose (dummy, LOCAL-ONLY credentials) --------------------
POSTGRES_DB=batch_inference
POSTGRES_USER=batch_user
POSTGRES_PASSWORD=batch_pass
AIRFLOW_SECRET_KEY=change-me-in-prod

# --- Cloud database (Neon) ---------------------------------------------------
# Single connection string from Neon's POOLED endpoint. Used by the Vercel API,
# the GitHub Actions nightly job, and score_batch.py. When set, it overrides the
# individual POSTGRES_* parts above.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/batch_inference?sslmode=require

# --- Kaggle (dataset download) -----------------------------------------------
# https://www.kaggle.com/account -> "Create New API Token"
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# --- API (production CORS) ---------------------------------------------------
# Comma-separated allowlist of dashboard origins. Omit locally (defaults to "*").
CORS_ORIGINS=https://your-dashboard.vercel.app

# --- Dashboard (Next.js, set in Vercel or dashboard/.env.local) --------------
# NEXT_PUBLIC_API_URL=https://your-api.vercel.app
